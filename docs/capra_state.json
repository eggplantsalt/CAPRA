  "key_constants": {
    "NUM_ACTIONS_CHUNK": 8,
    "ACTION_DIM": 7,
    "PROPRIO_DIM": 8,
    "default_action_mode": "L1_regression_continuous",
    "shuffle_buffer_size": 2000
  },

  "phase6_training_formula": {
    "anchor": "L1Loss(ground_truth_actions, predicted_actions)  -- always on",
    "capra": "lambda * sum_t w_t * KL(q_hat_t || pi_theta_t)  -- activated states only",
    "weight": "w_t = Delta_t * (1 + rho * R_t)",
    "pi_theta_approx": "softmax(-gamma * L1(a_i, a_hat))  over K candidates",
    "activation_conditions": [
      "capra_enabled=True",
      "use_l1_regression=True",
      "gradient_step_idx >= capra_warmup_steps",
      "capra_records non-empty",
      "q_hat_t non-zero (E_t was non-empty at mining time)"
    ]
  },

  "phase6_log_fields": [
    "anchor_loss",
    "capra_loss",
    "activation_ratio",
    "mean_w_t",
    "mean_delta_t",
    "loss_value",
    "curr_action_l1_loss"
  ],

  "phase6_edge_cases_open": [
    "Diffusion action head: CAPRA KL gated off (no analytic density)",
    "Multi-GPU: each rank reads full cache independently -- no sharding",
    "Empty cache: runs anchor-only with warning, no crash",
    "Resume: capra_warmup_steps counts from resume-start, not original step 0"
  ],

